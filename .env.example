# ── Groq ─────────────────────────────────────────────────────────
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────
# Obtener en: https://github.com/settings/tokens
# Permisos necesarios: public_repo (solo lectura)
GITHUB_TOKEN=

# ── LangSmith ────────────────────────────────────────────────────
# Obtener en: https://smith.langchain.com
# Sin LANGSMITH_API_KEY, los errores externos se registran solo en el logging
# estándar (la app sigue funcionando). Con clave, además se envían a LangSmith.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=code-review-agent
# Opcional: activa el trazado nativo de LangGraph en LangSmith.
LANGSMITH_TRACING=true

# ── Frontend ──────────────────────────────────────────────────────
# URL del backend. En desarrollo apunta a localhost; en producción al servidor desplegado.
VITE_BACKEND_URL=http://localhost:8000
